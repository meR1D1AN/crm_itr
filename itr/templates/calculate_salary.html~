{% extends 'lifts/base.html' %}

{% block content %}
<div class="container">
    <h2>Результаты расчета зарплаты за {{ month }}.{{ year }}</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Сотрудник</th>
                <th>Зарплата</th>
                <th>Стоимость дня</th>
            </tr>
        </thead>
        <tbody>
            {% for data in salary_data %}
            <tr>
                <td>{{ data.employee }}</td>
                <td>{{ data.salary }}</td>
                <td>{{ data.daily_rate }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}